# Core app
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=replace-with-a-long-random-secret
NEXT_PUBLIC_BILLING_MODE=manual
BILLING_MODE=manual
ADMIN_EMAILS=owner@example.com,admin@example.com

# Database
# Supabase / Postgres pooled connection for the app runtime.
DATABASE_URL=postgresql://postgres:password@db.example.supabase.co:6543/postgres?sslmode=require&pgbouncer=true

# Optional direct connection for admin tasks and future migration flows.
DIRECT_URL=postgresql://postgres:password@db.example.supabase.co:5432/postgres?sslmode=require

# Billing
# Leave billing mode as `manual` until Stripe is ready.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# Media uploads
# Use either CLOUDINARY_URL or the three discrete keys below.
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email
RESEND_API_KEY=
FROM_EMAIL=CardSaaS <noreply@example.com>

# Outgoing lead webhook auth
WEBHOOK_AUTH_TOKEN=
