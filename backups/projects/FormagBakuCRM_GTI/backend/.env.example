# Supabase Credentials
SUPABASE_URL=https://your-project.supabase.co

# Backend key: use service role in production backend
SUPABASE_SERVICE_ROLE_KEY=ey...

# Browser-safe key: publishable key (preferred) or anon key
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# SUPABASE_ANON_KEY=ey...

# Optional compatibility fallback for older local setups
SUPABASE_KEY=ey...

# Development-only bypass for local work before real auth users are created
ALLOW_DEV_AUTH_BYPASS=false

# n8n Webhook URLs
N8N_WEBHOOK_URL=https://n8n.2ai.az/webhook/agent-chat-2ai.az
N8N_WHATSAPP_SENDER_URL=https://n8n.2ai.az/webhook...

# SMTP Configuration (For automated emails sent via main.py)
# Used as a safe fallback when a personal sender profile is not configured yet.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USER=formagstatus@gmail.com
SMTP_PASSWORD=your_app_password_here
